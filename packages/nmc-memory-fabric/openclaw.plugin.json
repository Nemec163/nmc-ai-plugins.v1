{
  "openclawPlugin": "nmc-memory-fabric",
  "id": "nmc-memory-fabric",
  "kind": "memory",
  "name": "NMC Memory Fabric",
  "description": "QMD-first memory fabric with structured facts/decisions and semantic fallback",
  "version": "0.1.0",
  "source": "./index.ts",
  "skills": [
    "./skills/memory-layer-router"
  ],
  "admin": {
    "uiHandles": {
      "monitoring": [
        "/v1/memory/stats",
        "/v1/memory/quality",
        "/v1/memory/layers",
        "/v1/memory/catalog",
        "/v1/memory/conflicts"
      ],
      "bootstrap": "/v1/memory/bootstrap",
      "configPatch": "/v1/admin/plugins/nmc-memory-fabric/config"
    }
  },
  "uiHints": {
    "stateDir": {
      "label": "State Directory",
      "placeholder": "~/.openclaw/nmc-ai-plugins",
      "advanced": true
    },
    "autoRecall": {
      "label": "Auto Recall",
      "help": "Inject relevant memory snippets before agent execution."
    },
    "autoCapture": {
      "label": "Auto Capture",
      "help": "Capture high-signal facts from agent runs."
    },
    "autoRecallPrincipal": {
      "label": "Auto Recall Principal",
      "placeholder": "system:auto-recall",
      "advanced": true
    },
    "autoRecallActorLevel": {
      "label": "Auto Recall Actor Level",
      "placeholder": "A4_orchestrator_full",
      "advanced": true
    },
    "autoRecallLayers": {
      "label": "Auto Recall Layers",
      "help": "Limit which memory layers can be injected.",
      "advanced": true
    },
    "autoRecallMaxContextChars": {
      "label": "Auto Recall Context Budget",
      "placeholder": "1800",
      "advanced": true
    },
    "autoRecallMaxItems": {
      "label": "Auto Recall Max Items",
      "placeholder": "5",
      "advanced": true
    },
    "autoRecallMinScore": {
      "label": "Auto Recall Min Score",
      "placeholder": "0.45",
      "advanced": true
    },
    "autoCaptureMaxPerRun": {
      "label": "Auto Capture Max Per Run",
      "placeholder": "3",
      "advanced": true
    },
    "recallMinScore": {
      "label": "Recall Min Score",
      "placeholder": "0.32",
      "advanced": true
    },
    "maxFactChars": {
      "label": "Max Fact Chars",
      "placeholder": "1200",
      "advanced": true
    },
    "bootstrapAclEnabled": {
      "label": "Bootstrap ACL",
      "help": "Seed baseline grants for orchestrator and auto-recall principal."
    },
    "bootstrapAdminPrincipal": {
      "label": "Bootstrap Admin Principal",
      "placeholder": "orchestrator",
      "advanced": true
    },
    "bootstrapAdminActorLevel": {
      "label": "Bootstrap Admin Actor Level",
      "placeholder": "A4_orchestrator_full",
      "advanced": true
    },
    "bootstrapScopes": {
      "label": "Bootstrap Scopes",
      "help": "Scopes seeded for baseline ACL grants.",
      "advanced": true
    },
    "embedding.apiKey": {
      "label": "OpenAI API Key",
      "sensitive": true,
      "placeholder": "sk-proj-...",
      "help": "Used for vector embedding fallback."
    },
    "embedding.model": {
      "label": "Embedding Model",
      "placeholder": "text-embedding-3-small"
    },
    "qmd.paths": {
      "label": "QMD Paths",
      "help": "Directories scanned by QMD recall.",
      "advanced": true
    },
    "qmd.exclude": {
      "label": "QMD Exclude Patterns",
      "advanced": true
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "stateDir": {
        "type": "string"
      },
      "openclawConfigPath": {
        "type": "string"
      },
      "workspaceRoot": {
        "type": "string"
      },
      "autoRecall": {
        "type": "boolean"
      },
      "autoCapture": {
        "type": "boolean"
      },
      "autoRecallPrincipal": {
        "type": "string"
      },
      "autoRecallActorLevel": {
        "type": "string"
      },
      "autoRecallLayers": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "autoRecallMaxContextChars": {
        "type": "integer",
        "minimum": 256,
        "maximum": 6000
      },
      "autoRecallMaxItems": {
        "type": "integer",
        "minimum": 1,
        "maximum": 12
      },
      "autoRecallMinScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "autoCaptureMaxPerRun": {
        "type": "integer",
        "minimum": 1,
        "maximum": 10
      },
      "recallMinScore": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "maxFactChars": {
        "type": "integer",
        "minimum": 128,
        "maximum": 4000
      },
      "bootstrapAclEnabled": {
        "type": "boolean"
      },
      "bootstrapAdminPrincipal": {
        "type": "string"
      },
      "bootstrapAdminActorLevel": {
        "type": "string"
      },
      "bootstrapScopes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "embedding": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "apiKey": {
            "type": "string"
          },
          "model": {
            "type": "string"
          }
        },
        "required": [
          "apiKey"
        ]
      },
      "qmd": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exclude": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  },
