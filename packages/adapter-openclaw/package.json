{
  "name": "adapter-openclaw",
  "version": "0.1.0",
  "private": false,
  "description": "OpenClaw connector package for MemoryOS.v1.",
  "type": "commonjs",
  "main": "./index.js",
  "bin": {
    "memory-control-plane": "./bin/memory-control-plane.js",
    "memory-os-gateway": "./bin/memory-os-gateway.js"
  },
  "openclaw": {
    "extensions": ["./plugin.js"]
  },
  "exports": {
    ".": "./index.js",
    "./conformance-adapter": "./lib/conformance-adapter.js",
    "./install-surface": "./lib/install-surface.js",
    "./pipeline-adapter": "./lib/pipeline-adapter.js",
    "./plugin": "./plugin.js",
    "./register": "./lib/register.js",
    "./runtime-orchestration": "./lib/runtime-orchestration.js",
    "./setup": "./lib/openclaw-setup.js",
    "./setup-cli": "./lib/setup-cli.js"
  },
  "files": [
    "bin/",
    "control-plane/",
    "index.js",
    "lib/",
    "memory-agents/",
    "memory-canon/",
    "memory-contracts/",
    "memory-maintainer/",
    "memory-os-gateway/",
    "memory-os-runtime/",
    "memory-pipeline/",
    "memory-scripts/",
    "memory-workspace/",
    "openclaw.plugin.json",
    "plugin.js",
    "skills/",
    "templates/",
    "README.md"
  ],
  "scripts": {
    "test": "node ./test/validate-fixtures.js",
    "prepack": "node ./scripts/prepare-bundle.js build",
    "postpack": "node ./scripts/prepare-bundle.js clean"
  }
}
